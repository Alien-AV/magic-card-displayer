<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Status: DISARMED"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/connectionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="TV: disconnected"
            android:textSize="14sp" />

        <Button
            android:id="@+id/reconnectButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Discover/Connect TV"
            android:textAllCaps="false" />

        <EditText
            android:id="@+id/backgroundUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="https://example.com/background.jpg"
            android:inputType="textUri"
            android:maxLines="1" />

        <Button
            android:id="@+id/applyBackgroundButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Set TV Background URL"
            android:textAllCaps="false" />

        <CheckBox
            android:id="@+id/normalizeSpeechCheck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:checked="true"
            android:text="Use speech normalization (misheard words)" />

        <Button
            android:id="@+id/listenButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="20dp"
            android:text="ARM Listening"
            android:textAllCaps="false"
            android:textSize="22sp" />

        <Button
            android:id="@+id/stopButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="12dp"
            android:enabled="false"
            android:text="DISARM"
            android:textAllCaps="false"
            android:textSize="22sp" />

        <Button
            android:id="@+id/clearButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Send CLEAR to TV"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/lastTranscriptText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Last transcript: -"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/lastCardText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Last decoded card: -"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Status: DISARMED"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/connectionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="TV: Not connected"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/idleImageInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Idle background image URL"
            android:inputType="textUri"
            android:textSize="14sp" />

        <Button
            android:id="@+id/connectTvButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Discover + Connect TV"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/listenButton"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="20dp"
            android:text="Listen"
            android:textAllCaps="false"
            android:textSize="28sp" />

        <Button
            android:id="@+id/stopButton"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="12dp"
            android:enabled="false"
            android:text="Stop"
            android:textAllCaps="false"
            android:textSize="28sp" />

        <Button
            android:id="@+id/clearTvButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Clear TV card"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/lastTranscriptText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Last transcript: -"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/lastCardText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Last decoded card: -"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
